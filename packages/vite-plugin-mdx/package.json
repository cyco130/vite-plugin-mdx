{
  "name": "@cyco130/vite-plugin-mdx",
  "version": "3.0.0",
  "description": "Vite plugin for using MDX",
  "keywords": [
    "mdx",
    "vite"
  ],
  "license": "MIT",
  "repository": "github:cyco130/vite-plugin-mdx",
  "files": [
    "dist"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "dist/*.d.ts"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "rm -rf dist && pnpm build",
    "test": "pnpm test:typecheck && pnpm test:lint && pnpm test:package",
    "test:typecheck": "tsc -p tsconfig.json --noEmit",
    "test:lint": "eslint . --max-warnings 0 --ignore-pattern dist",
    "test:package": "publint --strict"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "source-map": "^0.7.6",
    "vfile": "^6.0.3"
  },
  "devDependencies": {
    "@cyco130/eslint-config": "^7.0.0",
    "@types/node": "^20.19.37",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "publint": "^0.3.18",
    "tsdown": "0.21.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "peerDependencies": {
    "vite": "7 || 8"
  }
}
